<Window x:Class="NotepadRedo.DiffMergeWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Resolve differences" Height="660" Width="1120"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource Theme.WindowBg}">
    <DockPanel>
        <!-- Re-change banner (shown when the file changes again while merging) -->
        <Border x:Name="Banner" DockPanel.Dock="Top" Visibility="Collapsed"
                Background="#4D8A6D3B" Padding="10,6" BorderBrush="#E0A93B" BorderThickness="0,0,0,1">
            <DockPanel LastChildFill="False">
                <TextBlock x:Name="BannerText" DockPanel.Dock="Left" VerticalAlignment="Center"
                           Foreground="{DynamicResource Theme.EditorFg}"
                           Text="The file changed on disk again."/>
                <Button x:Name="BannerButton" DockPanel.Dock="Right" Content="Review…"
                        Padding="10,3" Click="Banner_Click"/>
            </DockPanel>
        </Border>

        <!-- Toolbar -->
        <Border DockPanel.Dock="Top" Background="{DynamicResource Theme.PanelBg}"
                BorderBrush="{DynamicResource Theme.PanelBorder}" BorderThickness="0,0,0,1" Padding="10,6">
            <DockPanel LastChildFill="False">
                <TextBlock Text="Keeping:" VerticalAlignment="Center" Margin="0,0,8,0"
                           Foreground="{DynamicResource Theme.EditorFg}"/>
                <RadioButton x:Name="KeepLeftRadio" Content="Mine (editor)" GroupName="Keep"
                             VerticalAlignment="Center" Margin="0,0,12,0"
                             Foreground="{DynamicResource Theme.EditorFg}"
                             Checked="KeepSide_Changed"/>
                <RadioButton x:Name="KeepRightRadio" Content="On disk" GroupName="Keep"
                             VerticalAlignment="Center" Margin="0,0,16,0"
                             Foreground="{DynamicResource Theme.EditorFg}"
                             Checked="KeepSide_Changed"/>
                <Button Content="Re-diff" Padding="10,3" Margin="0,0,8,0" Click="Rediff_Click"
                        ToolTip="Recompute the highlights after editing the kept side by hand"/>

                <Button DockPanel.Dock="Right" Content="Cancel" Padding="12,3" Margin="8,0,0,0" Click="Cancel_Click"/>
                <Button DockPanel.Dock="Right" x:Name="SaveBothButton" Content="Save both"
                        Padding="12,3" Margin="8,0,0,0" Click="SaveBoth_Click"
                        ToolTip="Save the kept side as the file, and the other side to a separate timestamped file next to it"/>
                <Button DockPanel.Dock="Right" x:Name="SaveButton" Content="Save kept side"
                        Padding="12,3" Click="Save_Click"
                        ToolTip="Save only the kept side as the file, discarding the other side"/>
            </DockPanel>
        </Border>

        <!-- Hint -->
        <Border DockPanel.Dock="Bottom" Background="{DynamicResource Theme.PanelBg}"
                BorderBrush="{DynamicResource Theme.PanelBorder}" BorderThickness="0,1,0,0" Padding="10,4">
            <TextBlock x:Name="HintText" FontSize="11" Foreground="{DynamicResource Theme.TreeMetaFg}"
                       Text="Double-click a red line on the source side to copy it into the kept side. Right-click a red line for more options. The kept side (outlined) is editable."/>
        </Border>

        <!-- Two panes -->
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="6"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <DockPanel Grid.Column="0" Margin="6">
                <TextBlock x:Name="LeftHeader" DockPanel.Dock="Top" FontWeight="Bold" Margin="2,0,0,4"
                           Foreground="{DynamicResource Theme.TreePreviewFg}" Text="Mine (editor)"/>
                <Border x:Name="LeftOutline" BorderThickness="2" BorderBrush="Transparent">
                    <RichTextBox x:Name="LeftBox" IsReadOnly="True"
                                 FontFamily="Consolas" FontSize="13"
                                 VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto"
                                 Background="{DynamicResource Theme.EditorBg}"
                                 Foreground="{DynamicResource Theme.EditorFg}"
                                 AcceptsReturn="True"/>
                </Border>
            </DockPanel>

            <GridSplitter Grid.Column="1" Width="6" HorizontalAlignment="Stretch"
                          Background="{DynamicResource Theme.Splitter}"/>

            <DockPanel Grid.Column="2" Margin="6">
                <TextBlock x:Name="RightHeader" DockPanel.Dock="Top" FontWeight="Bold" Margin="2,0,0,4"
                           Foreground="{DynamicResource Theme.TreePreviewFg}" Text="On disk"/>
                <Border x:Name="RightOutline" BorderThickness="2" BorderBrush="Transparent">
                    <RichTextBox x:Name="RightBox" IsReadOnly="True"
                                 FontFamily="Consolas" FontSize="13"
                                 VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto"
                                 Background="{DynamicResource Theme.EditorBg}"
                                 Foreground="{DynamicResource Theme.EditorFg}"
                                 AcceptsReturn="True"/>
                </Border>
            </DockPanel>
        </Grid>
    </DockPanel>
</Window>
