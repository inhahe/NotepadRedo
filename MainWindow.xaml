<Window x:Class="NotepadRedo.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="NotepadRedo" Height="640" Width="1000"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource Theme.WindowBg}"
        AllowDrop="True">

    <DockPanel>
        <!-- ============ Menu ============ -->
        <Menu DockPanel.Dock="Top">
            <MenuItem Header="_File">
                <MenuItem Header="_New"        Click="New_Click"     InputGestureText="Ctrl+N"/>
                <MenuItem Header="_Open..."    Click="Open_Click"    InputGestureText="Ctrl+O"/>
                <Separator/>
                <MenuItem Header="_Save"       Click="Save_Click"    InputGestureText="Ctrl+S"/>
                <MenuItem Header="Save _As..." Click="SaveAs_Click"  InputGestureText="Ctrl+Shift+S"/>
                <Separator/>
                <MenuItem Header="_Close Tab"  Click="CloseTab_Click" InputGestureText="Ctrl+W"/>
                <MenuItem Header="E_xit"       Click="Exit_Click"/>
            </MenuItem>
            <MenuItem Header="_Edit">
                <MenuItem Header="_Undo"  Click="Undo_Click" InputGestureText="Ctrl+Z"/>
                <MenuItem Header="_Redo"  Click="Redo_Click" InputGestureText="Ctrl+Y"/>
                <Separator/>
                <MenuItem Header="Cu_t"   Command="Cut"/>
                <MenuItem Header="_Copy"  Command="Copy"/>
                <MenuItem Header="_Paste" Command="Paste"/>
                <Separator/>
                <MenuItem Header="_Find..." Click="Find_Click" InputGestureText="Ctrl+F"/>
            </MenuItem>
            <MenuItem Header="F_ormat">
                <MenuItem Header="_Font..." Click="Font_Click"/>
                <Separator/>
                <MenuItem x:Name="BoldItem"   Header="_Bold"   IsCheckable="True"
                          InputGestureText="Ctrl+B" Click="Bold_Click"/>
                <MenuItem x:Name="ItalicItem" Header="_Italic" IsCheckable="True"
                          InputGestureText="Ctrl+I" Click="Italic_Click"/>
                <Separator/>
                <MenuItem x:Name="FontSizeMenu" Header="_Size">
                    <MenuItem Header="8"  IsCheckable="True" Tag="8"  Click="FontSize_Click"/>
                    <MenuItem Header="9"  IsCheckable="True" Tag="9"  Click="FontSize_Click"/>
                    <MenuItem Header="10" IsCheckable="True" Tag="10" Click="FontSize_Click"/>
                    <MenuItem Header="11" IsCheckable="True" Tag="11" Click="FontSize_Click"/>
                    <MenuItem Header="12" IsCheckable="True" Tag="12" Click="FontSize_Click"/>
                    <MenuItem Header="14" IsCheckable="True" Tag="14" Click="FontSize_Click"/>
                    <MenuItem Header="16" IsCheckable="True" Tag="16" Click="FontSize_Click"/>
                    <MenuItem Header="18" IsCheckable="True" Tag="18" Click="FontSize_Click"/>
                    <MenuItem Header="20" IsCheckable="True" Tag="20" Click="FontSize_Click"/>
                    <MenuItem Header="24" IsCheckable="True" Tag="24" Click="FontSize_Click"/>
                    <MenuItem Header="28" IsCheckable="True" Tag="28" Click="FontSize_Click"/>
                    <MenuItem Header="36" IsCheckable="True" Tag="36" Click="FontSize_Click"/>
                    <MenuItem Header="48" IsCheckable="True" Tag="48" Click="FontSize_Click"/>
                    <MenuItem Header="72" IsCheckable="True" Tag="72" Click="FontSize_Click"/>
                </MenuItem>
            </MenuItem>
            <MenuItem Header="_View">
                <MenuItem x:Name="WordWrapItem" Header="_Word Wrap" IsCheckable="True"
                          IsChecked="True" Click="WordWrap_Click"/>
                <MenuItem x:Name="ShowTreeItem" Header="Show _History Tree" IsCheckable="True"
                          IsChecked="True" Click="ShowTree_Click"/>
            </MenuItem>
            <MenuItem Header="_Options">
                <MenuItem Header="Open new files in...">
                    <MenuItem x:Name="OpenInTabItem"      Header="A new _tab"      IsCheckable="True"
                              Click="OpenTarget_Click" Tag="tab"/>
                    <MenuItem x:Name="OpenInInstanceItem" Header="A new _instance" IsCheckable="True"
                              Click="OpenTarget_Click" Tag="instance"/>
                </MenuItem>
                <Separator/>
                <MenuItem Header="When the _X button is clicked...">
                    <MenuItem x:Name="CloseCloses"    Header="_Close the window"     IsCheckable="True"
                              Click="CloseBehavior_Click" Tag="Close"/>
                    <MenuItem x:Name="CloseToTray"    Header="Minimize to _tray"     IsCheckable="True"
                              Click="CloseBehavior_Click" Tag="MinimizeToTray"/>
                    <MenuItem x:Name="CloseToTaskbar" Header="Minimize to task_bar"  IsCheckable="True"
                              Click="CloseBehavior_Click" Tag="MinimizeToTaskbar"/>
                </MenuItem>
                <Separator/>
                <MenuItem Header="_Autosave (crash recovery)">
                    <MenuItem x:Name="AutoOff"  Header="Off"              IsCheckable="True" Tag="0"   Click="AutosaveInterval_Click"/>
                    <MenuItem x:Name="Auto15"   Header="Every 15 seconds" IsCheckable="True" Tag="15"  Click="AutosaveInterval_Click"/>
                    <MenuItem x:Name="Auto30"   Header="Every 30 seconds" IsCheckable="True" Tag="30"  Click="AutosaveInterval_Click"/>
                    <MenuItem x:Name="Auto60"   Header="Every minute"     IsCheckable="True" Tag="60"  Click="AutosaveInterval_Click"/>
                    <MenuItem x:Name="Auto300"  Header="Every 5 minutes"  IsCheckable="True" Tag="300" Click="AutosaveInterval_Click"/>
                </MenuItem>
                <Separator/>
                <MenuItem Header="Reopen last _session's files at startup">
                    <MenuItem x:Name="RestorePrompt" Header="_Ask me first"       IsCheckable="True"
                              Click="RestoreMode_Click" Tag="Prompt"/>
                    <MenuItem x:Name="RestoreAlways" Header="_Always reopen"       IsCheckable="True"
                              Click="RestoreMode_Click" Tag="Always"/>
                    <MenuItem x:Name="RestoreNever"  Header="_Never reopen"        IsCheckable="True"
                              Click="RestoreMode_Click" Tag="Never"/>
                </MenuItem>
                <Separator/>
                <MenuItem x:Name="WatchChangesItem" Header="_Watch for changes made by other programs"
                          IsCheckable="True" Click="WatchChanges_Click"/>
                <MenuItem x:Name="LockFileItem" Header="_Lock open files from outside changes"
                          IsCheckable="True" Click="LockFile_Click"/>
                <MenuItem x:Name="PersistHistoryItem" Header="_Remember edit history between sessions"
                          IsCheckable="True" Click="PersistHistory_Click"/>
                <Separator/>
                <MenuItem Header="_Undo grouping">
                    <MenuItem x:Name="UndoBreakEnter" Header="New step on each _line (Enter)"
                              IsCheckable="True" Click="UndoBreakEnter_Click"/>
                    <MenuItem x:Name="UndoBreakPaste" Header="New step on each _paste"
                              IsCheckable="True" Click="UndoBreakPaste_Click"/>
                    <MenuItem x:Name="UndoPerChar" Header="New step on each _character"
                              IsCheckable="True" Click="UndoPerChar_Click"/>
                    <Separator/>
                    <MenuItem Header="New step after a typing pause of...">
                        <MenuItem x:Name="UndoPause1"  Header="1 second"  IsCheckable="True" Tag="1" Click="UndoPause_Click"/>
                        <MenuItem x:Name="UndoPause2"  Header="2 seconds" IsCheckable="True" Tag="2" Click="UndoPause_Click"/>
                        <MenuItem x:Name="UndoPause4"  Header="4 seconds" IsCheckable="True" Tag="4" Click="UndoPause_Click"/>
                        <MenuItem x:Name="UndoPause8"  Header="8 seconds" IsCheckable="True" Tag="8" Click="UndoPause_Click"/>
                        <Separator/>
                        <MenuItem x:Name="UndoPauseCustom" Header="Custom..." IsCheckable="True" Click="UndoPauseCustom_Click"/>
                    </MenuItem>
                </MenuItem>
            </MenuItem>
        </Menu>

        <!-- ============ Toolbar ============ -->
        <ToolBarTray DockPanel.Dock="Top" IsLocked="True" Background="{DynamicResource Theme.ToolbarBg}">
            <ToolBar ToolBarTray.IsLocked="True" Padding="2" Background="{DynamicResource Theme.ToolbarBg}">
                <ToggleButton x:Name="TreeToggle" Click="ToggleTree_Click"
                              Padding="6,2" ToolTip="Show/hide the history tree">
                    <StackPanel Orientation="Horizontal">
                        <Canvas Width="16" Height="16" VerticalAlignment="Center">
                            <Line X1="4" Y1="4" X2="4" Y2="12" Stroke="{DynamicResource Theme.ToolbarFg}" StrokeThickness="1.5"/>
                            <Line X1="4" Y1="8" X2="11" Y2="8" Stroke="{DynamicResource Theme.ToolbarFg}" StrokeThickness="1.5"/>
                            <Ellipse Canvas.Left="2" Canvas.Top="2"  Width="4" Height="4" Fill="{DynamicResource Theme.ToolbarFg}"/>
                            <Ellipse Canvas.Left="2" Canvas.Top="10" Width="4" Height="4" Fill="{DynamicResource Theme.ToolbarFg}"/>
                            <Ellipse Canvas.Left="9" Canvas.Top="6"  Width="4" Height="4" Fill="{DynamicResource Theme.ToolbarFg}"/>
                        </Canvas>
                        <TextBlock Text="History Tree" Margin="6,0,0,0" VerticalAlignment="Center"
                                   Foreground="{DynamicResource Theme.ToolbarFg}"/>
                    </StackPanel>
                </ToggleButton>
                <ToggleButton x:Name="SearchToggle" Click="ToggleSearch_Click"
                              Padding="6,2" ToolTip="Show/hide the search pane">
                    <StackPanel Orientation="Horizontal">
                        <Canvas Width="16" Height="16" VerticalAlignment="Center">
                            <Ellipse Canvas.Left="2" Canvas.Top="2" Width="8" Height="8"
                                     Stroke="{DynamicResource Theme.ToolbarFg}" StrokeThickness="1.5"/>
                            <Line X1="9" Y1="9" X2="13" Y2="13"
                                  Stroke="{DynamicResource Theme.ToolbarFg}" StrokeThickness="1.5"/>
                        </Canvas>
                        <TextBlock Text="Search" Margin="6,0,0,0" VerticalAlignment="Center"
                                   Foreground="{DynamicResource Theme.ToolbarFg}"/>
                    </StackPanel>
                </ToggleButton>
            </ToolBar>
        </ToolBarTray>

        <!-- ============ Status bar ============ -->
        <StatusBar DockPanel.Dock="Bottom"
                   Background="{DynamicResource Theme.StatusBg}"
                   Foreground="{DynamicResource Theme.StatusFg}">
            <StatusBarItem>
                <TextBlock x:Name="CaretStatus" Text="Ln 1, Col 1"/>
            </StatusBarItem>
            <Separator/>
            <StatusBarItem>
                <TextBlock x:Name="CountStatus" Text="0 chars"/>
            </StatusBarItem>
            <Separator/>
            <StatusBarItem>
                <TextBlock x:Name="NodeStatus" Text="node #0"/>
            </StatusBarItem>
            <StatusBarItem HorizontalAlignment="Right">
                <TextBlock x:Name="SaveStatus" Text="Saved" FontWeight="Bold" Foreground="ForestGreen"/>
            </StatusBarItem>
        </StatusBar>

        <!-- ============ Tabs ============ -->
        <TabControl x:Name="Tabs" SelectionChanged="Tabs_SelectionChanged">
            <TabControl.ItemContainerStyle>
                <Style TargetType="TabItem">
                    <!-- Drag a header to reorder / tear off / reattach across windows. -->
                    <EventSetter Event="PreviewMouseLeftButtonDown" Handler="Tab_PreviewMouseLeftButtonDown"/>
                    <EventSetter Event="PreviewMouseMove"           Handler="Tab_PreviewMouseMove"/>
                    <EventSetter Event="MouseDown"                  Handler="Tab_MouseDown"/>
                </Style>
            </TabControl.ItemContainerStyle>
        </TabControl>
    </DockPanel>
</Window>
