<UserControl x:Class="NotepadRedo.EditorView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:NotepadRedo">
    <UserControl.Resources>
        <local:PreviewWidthConverter x:Key="PreviewWidth"/>
        <local:IndentMarginConverter x:Key="IndentMargin"/>
    </UserControl.Resources>
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" MinWidth="200"/>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition x:Name="TreeColumn" Width="340" MinWidth="80"/>
            <ColumnDefinition x:Name="SearchColumn" Width="0" MinWidth="0"/>
        </Grid.ColumnDefinitions>

        <TextBox x:Name="Editor" Grid.Column="0"
                 AcceptsReturn="True" AcceptsTab="True"
                 TextWrapping="Wrap"
                 VerticalScrollBarVisibility="Auto"
                 HorizontalScrollBarVisibility="Auto"
                 FontFamily="Consolas" FontSize="14"
                 IsUndoEnabled="False"
                 Background="{DynamicResource Theme.EditorBg}"
                 Foreground="{DynamicResource Theme.EditorFg}"
                 CaretBrush="{DynamicResource Theme.EditorFg}"
                 Padding="6"
                 PreviewKeyDown="Editor_PreviewKeyDown"
                 PreviewMouseLeftButtonDown="Editor_PreviewMouseLeftButtonDown"
                 TextChanged="Editor_TextChanged"
                 SelectionChanged="Editor_SelectionChanged"/>

        <!-- Manual splitter: a bare GridSplitter would not resize the fixed tree column in this
             layout, and a Thumb stops firing once it repositions under the cursor. So we capture
             the mouse ourselves and drive TreeColumn.Width from the cursor's position relative to
             this control (a stable ancestor), which never "sticks". -->
        <Border x:Name="Splitter" Grid.Column="1" Width="6"
                HorizontalAlignment="Stretch" VerticalAlignment="Stretch"
                Background="{DynamicResource Theme.Splitter}" Cursor="SizeWE"
                MouseLeftButtonDown="Splitter_MouseLeftButtonDown"
                MouseMove="Splitter_MouseMove"
                MouseLeftButtonUp="Splitter_MouseLeftButtonUp"/>

        <DockPanel x:Name="TreePanel" Grid.Column="2" Margin="4">
            <Border DockPanel.Dock="Top" Background="{DynamicResource Theme.PanelBg}" Padding="6" Margin="0,0,0,4"
                    BorderBrush="{DynamicResource Theme.PanelBorder}" BorderThickness="1">
                <StackPanel>
                    <DockPanel LastChildFill="False">
                        <TextBlock Text="History Tree" FontWeight="Bold" VerticalAlignment="Center"
                                   Foreground="{DynamicResource Theme.TreePreviewFg}" DockPanel.Dock="Left"/>
                        <!-- Condense long straight typing runs to branch points/tips/current (default),
                             or check to reveal one row per edit. Shared, persisted across all views. -->
                        <ToggleButton x:Name="ShowAllEditsToggle" Content="Show all edits"
                                      Style="{StaticResource {x:Static ToolBar.ToggleButtonStyleKey}}"
                                      DockPanel.Dock="Right" Padding="6,1" VerticalAlignment="Center"
                                      ToolTip="Show every edit as its own row instead of condensing straight runs to branch points"
                                      Checked="ShowAllEdits_Changed" Unchecked="ShowAllEdits_Changed"/>
                    </DockPanel>
                    <CheckBox x:Name="FitWidthCheck" Content="Fit preview to width"
                              Margin="0,4,0,0" VerticalAlignment="Center"
                              Checked="FitWidth_Changed" Unchecked="FitWidth_Changed"/>
                    <DockPanel x:Name="PreviewCharsRow" Margin="0,4,0,0" LastChildFill="True">
                        <TextBlock Text="Preview chars:" VerticalAlignment="Center" DockPanel.Dock="Left"/>
                        <TextBlock x:Name="PreviewLenLabel" Text="30" VerticalAlignment="Center"
                                   Width="24" TextAlignment="Right" DockPanel.Dock="Right"/>
                        <!-- IsMoveToPointEnabled lets a click anywhere on the track jump the thumb
                             there, so it's far easier to move than a small draggable thumb. -->
                        <Slider x:Name="PreviewSlider" Margin="6,0"
                                Minimum="5" Maximum="80" Value="30"
                                TickFrequency="5" IsSnapToTickEnabled="True"
                                IsMoveToPointEnabled="True"
                                VerticalAlignment="Center"
                                ValueChanged="PreviewSlider_ValueChanged"/>
                    </DockPanel>
                </StackPanel>
            </Border>

            <!-- Flattened history list: a straight run of edits shows as a flat column; only real
                 fork points (a node with more than one child — i.e. an ambiguous redo) step the
                 following branch rows further right via the per-row indent margin. Selection is
                 shown by our own IsCurrent / IsSelected border styling, not the default highlight. -->
            <ListBox x:Name="Tree"
                     SelectionChanged="Tree_SelectionChanged"
                     Background="{DynamicResource Theme.TreeBg}"
                     BorderBrush="{DynamicResource Theme.PanelBorder}" BorderThickness="1"
                     HorizontalContentAlignment="Stretch"
                     ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                <ListBox.Resources>
                    <SolidColorBrush x:Key="{x:Static SystemColors.HighlightBrushKey}" Color="Transparent"/>
                    <SolidColorBrush x:Key="{x:Static SystemColors.HighlightTextBrushKey}" Color="#222222"/>
                    <SolidColorBrush x:Key="{x:Static SystemColors.InactiveSelectionHighlightBrushKey}" Color="Transparent"/>
                    <SolidColorBrush x:Key="{x:Static SystemColors.InactiveSelectionHighlightTextBrushKey}" Color="#222222"/>
                </ListBox.Resources>
                <ListBox.ItemContainerStyle>
                    <Style TargetType="ListBoxItem">
                        <Setter Property="IsSelected" Value="{Binding IsSelected, Mode=TwoWay}"/>
                        <Setter Property="Padding" Value="0"/>
                        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                    </Style>
                </ListBox.ItemContainerStyle>
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <Border CornerRadius="3" Padding="6,3" Margin="{Binding IndentLevel, Converter={StaticResource IndentMargin}}">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Setter Property="Background" Value="Transparent"/>
                                    <Setter Property="BorderThickness" Value="1"/>
                                    <Setter Property="BorderBrush" Value="Transparent"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                            <Setter Property="Background" Value="{DynamicResource Theme.NodeSelBg}"/>
                                            <Setter Property="BorderBrush" Value="{DynamicResource Theme.NodeSelBorder}"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding IsCurrent}" Value="True">
                                            <Setter Property="Background" Value="{DynamicResource Theme.NodeCurBg}"/>
                                            <Setter Property="BorderBrush" Value="{DynamicResource Theme.NodeCurBorder}"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <StackPanel>
                                <TextBlock Text="{Binding Preview}" FontFamily="Consolas" FontSize="13"
                                           Foreground="{DynamicResource Theme.TreePreviewFg}"
                                           TextWrapping="NoWrap" TextTrimming="CharacterEllipsis">
                                    <TextBlock.MaxWidth>
                                        <MultiBinding Converter="{StaticResource PreviewWidth}">
                                            <Binding Path="ActualWidth" RelativeSource="{RelativeSource AncestorType=ListBox}"/>
                                            <Binding Path="IndentLevel"/>
                                        </MultiBinding>
                                    </TextBlock.MaxWidth>
                                </TextBlock>
                                <TextBlock Text="{Binding Meta}" Foreground="{DynamicResource Theme.TreeMetaFg}" FontSize="10"
                                           TextWrapping="NoWrap" TextTrimming="CharacterEllipsis"/>
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </DockPanel>

        <!-- ===================== Search pane (far right, toggled by Ctrl+F) ===================== -->
        <DockPanel x:Name="SearchPanel" Grid.Column="3" Margin="4" Visibility="Collapsed">
            <Border DockPanel.Dock="Top" Background="{DynamicResource Theme.PanelBg}" Padding="6" Margin="0,0,0,4"
                    BorderBrush="{DynamicResource Theme.PanelBorder}" BorderThickness="1">
                <StackPanel>
                    <DockPanel LastChildFill="False">
                        <TextBlock Text="Search" FontWeight="Bold" DockPanel.Dock="Left"
                                   VerticalAlignment="Center" Foreground="{DynamicResource Theme.TreePreviewFg}"/>
                        <Button x:Name="SearchCloseButton" DockPanel.Dock="Right" Content="&#x2715;"
                                Width="20" Height="20" Padding="0" ToolTip="Close search (Esc)"
                                Click="SearchClose_Click"/>
                    </DockPanel>

                    <TextBox x:Name="SearchBox" Margin="0,6,0,0"
                             Background="{DynamicResource Theme.EditorBg}"
                             Foreground="{DynamicResource Theme.EditorFg}"
                             CaretBrush="{DynamicResource Theme.EditorFg}"
                             Padding="4,3"
                             ToolTip="Type text to find — matched exactly as typed."
                             TextChanged="SearchInput_Changed"
                             PreviewKeyDown="SearchBox_PreviewKeyDown"/>

                    <!-- Proximity item-list mode: shown only while the "near each other" box is checked.
                         The search box above becomes the entry field — press Enter to add each item;
                         every added item shows here with an X to remove it and stays editable. -->
                    <StackPanel x:Name="TermListPanel" Visibility="Collapsed">
                        <TextBlock x:Name="AddTermHint" Margin="0,4,0,0" FontSize="11"
                                   TextWrapping="Wrap" Foreground="{DynamicResource Theme.TreeMetaFg}"
                                   Text="Press Enter to add each item to match near the others."/>
                        <!-- Focusable=False + TabNavigation=Continue so Tab from the add box lands on
                             the first item's field, not a focus rectangle around the whole control. -->
                        <ItemsControl x:Name="TermsList" Margin="0,4,0,0"
                                      Focusable="False" KeyboardNavigation.TabNavigation="Continue">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <DockPanel Margin="0,2,0,0" LastChildFill="True">
                                        <Button DockPanel.Dock="Right" Content="&#x2715;"
                                                Width="20" Height="20" Padding="0" Margin="4,0,0,0"
                                                IsTabStop="False"
                                                Click="RemoveTerm_Click" ToolTip="Remove this item"/>
                                        <TextBox Text="{Binding Text, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                 Background="{DynamicResource Theme.EditorBg}"
                                                 Foreground="{DynamicResource Theme.EditorFg}"
                                                 CaretBrush="{DynamicResource Theme.EditorFg}"
                                                 Padding="4,2"
                                                 TextChanged="TermEdit_Changed"
                                                 PreviewKeyDown="TermEdit_PreviewKeyDown"/>
                                    </DockPanel>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>

                    <CheckBox x:Name="CaseSensitiveCheck" Content="Case sensitive" Margin="0,6,0,0"
                              Foreground="{DynamicResource Theme.TreePreviewFg}"
                              Checked="SearchOption_Changed" Unchecked="SearchOption_Changed"/>

                    <CheckBox x:Name="WholeWordCheck" Content="Match whole word only" Margin="0,6,0,0"
                              Foreground="{DynamicResource Theme.TreePreviewFg}"
                              ToolTip="Only match when the term stands alone as a word (not inside a longer word)"
                              Checked="SearchOption_Changed" Unchecked="SearchOption_Changed"/>

                    <CheckBox x:Name="ProximityCheck" Margin="0,6,0,0"
                              Foreground="{DynamicResource Theme.TreePreviewFg}"
                              Content="Only where all items are near each other"
                              Checked="Proximity_Changed" Unchecked="Proximity_Changed"/>

                    <DockPanel x:Name="ProximityRow" Margin="16,4,0,0" LastChildFill="False"
                               Visibility="Collapsed">
                        <TextBlock Text="within" VerticalAlignment="Center" DockPanel.Dock="Left"
                                   Foreground="{DynamicResource Theme.TreePreviewFg}"/>
                        <TextBox x:Name="ProximityN" Text="40" Width="40" Margin="6,0"
                                 DockPanel.Dock="Left" TextAlignment="Right"
                                 Background="{DynamicResource Theme.EditorBg}"
                                 Foreground="{DynamicResource Theme.EditorFg}"
                                 CaretBrush="{DynamicResource Theme.EditorFg}"
                                 TextChanged="SearchInput_Changed"/>
                        <ComboBox x:Name="ProximityUnitBox" Width="96" DockPanel.Dock="Left"
                                  SelectionChanged="SearchUnit_Changed">
                            <ComboBoxItem Content="characters" IsSelected="True"/>
                            <ComboBoxItem Content="words"/>
                            <ComboBoxItem Content="lines"/>
                        </ComboBox>
                    </DockPanel>

                    <TextBlock x:Name="SearchStatus" Margin="0,6,0,0" FontSize="11"
                               Foreground="{DynamicResource Theme.TreeMetaFg}" Text=""/>
                </StackPanel>
            </Border>

            <ListBox x:Name="ResultsList"
                     Background="{DynamicResource Theme.TreeBg}"
                     BorderBrush="{DynamicResource Theme.PanelBorder}" BorderThickness="1"
                     ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                     HorizontalContentAlignment="Stretch"
                     SelectionChanged="Results_SelectionChanged">
                <ListBox.ItemContainerStyle>
                    <Style TargetType="ListBoxItem">
                        <Setter Property="Padding" Value="4,3"/>
                        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                    </Style>
                </ListBox.ItemContainerStyle>
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <StackPanel>
                            <!-- Preview: up to two lines, ellipsised if it overflows. -->
                            <TextBlock Text="{Binding Preview}" FontFamily="Consolas" FontSize="12"
                                       Foreground="{DynamicResource Theme.TreePreviewFg}"
                                       TextWrapping="Wrap" TextTrimming="CharacterEllipsis"
                                       MaxHeight="34"/>
                            <TextBlock Text="{Binding Location}" FontSize="10"
                                       Foreground="{DynamicResource Theme.TreeMetaFg}"/>
                        </StackPanel>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </DockPanel>
    </Grid>
</UserControl>
