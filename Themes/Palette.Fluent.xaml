<!-- "Fluent" — a light, airy Windows 11-style theme with a blue accent and soft blue-grey chrome. -->
<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <SolidColorBrush x:Key="Theme.WindowBg"    Color="#FFFFFF"/>
    <SolidColorBrush x:Key="Theme.EditorBg"    Color="#FFFFFF"/>
    <SolidColorBrush x:Key="Theme.EditorFg"    Color="#1B1B1B"/>

    <SolidColorBrush x:Key="Theme.ToolbarBg"   Color="#F3F6FB"/>
    <SolidColorBrush x:Key="Theme.ToolbarFg"   Color="#3A5A8C"/>

    <SolidColorBrush x:Key="Theme.Splitter"    Color="#E1E6EE"/>

    <SolidColorBrush x:Key="Theme.PanelBg"      Color="#F5F8FD"/>
    <SolidColorBrush x:Key="Theme.PanelBorder"  Color="#E1E6EE"/>
    <SolidColorBrush x:Key="Theme.TreeBg"       Color="#FFFFFF"/>
    <SolidColorBrush x:Key="Theme.TreePreviewFg" Color="#1B1B1B"/>
    <SolidColorBrush x:Key="Theme.TreeMetaFg"   Color="#8A93A2"/>
    <SolidColorBrush x:Key="Theme.NodeSelBg"    Color="#E8F0FE"/>
    <SolidColorBrush x:Key="Theme.NodeSelBorder" Color="#B9D3FB"/>
    <SolidColorBrush x:Key="Theme.NodeCurBg"    Color="#D2E3FF"/>
    <SolidColorBrush x:Key="Theme.NodeCurBorder" Color="#0F6CBD"/>

    <SolidColorBrush x:Key="Theme.StatusBg"    Color="#F3F6FB"/>
    <SolidColorBrush x:Key="Theme.StatusFg"    Color="#3A3A3A"/>

    <SolidColorBrush x:Key="Theme.Accent"      Color="#0F6CBD"/>
    <SolidColorBrush x:Key="Theme.AccentHover" Color="#0E5FA6"/>
    <SolidColorBrush x:Key="Theme.AccentText"  Color="#FFFFFF"/>
    <SolidColorBrush x:Key="Theme.AccentSoft"  Color="#DCEAFB"/>
    <SolidColorBrush x:Key="Theme.ButtonBg"    Color="#FBFCFE"/>
    <SolidColorBrush x:Key="Theme.ButtonBorder" Color="#D2D8E2"/>
    <SolidColorBrush x:Key="Theme.ButtonHover" Color="#EEF3FB"/>
    <SolidColorBrush x:Key="Theme.ButtonText"  Color="#1B1B1B"/>
</ResourceDictionary>
