<Application x:Class="NotepadRedo.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Application.Resources>
        <ResourceDictionary>
            <!-- Base palette so every DynamicResource "Theme.*" key resolves. The plain
                 NotepadRedo.exe uses these (its original colours); the stylised variant exes
                 merge an overriding palette + Controls.xaml at startup (see App.xaml.cs). -->
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Themes/Palette.Base.xaml"/>
            </ResourceDictionary.MergedDictionaries>

            <!-- Modern flat tab close button: transparent by default, a soft rounded highlight on
                 hover, and the familiar red pill when pressed. The glyph is a vector X so it stays
                 crisp at any DPI. -->
            <Style x:Key="TabCloseButton" TargetType="Button">
            <Setter Property="Width" Value="18"/>
            <Setter Property="Height" Value="18"/>
            <Setter Property="Margin" Value="6,0,0,0"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#909090"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="SnapsToDevicePixels" Value="True"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bg" Background="{TemplateBinding Background}" CornerRadius="4">
                            <Path x:Name="glyph"
                                  Data="M0,0 L8,8 M8,0 L0,8"
                                  Stroke="{TemplateBinding Foreground}"
                                  StrokeThickness="1.4"
                                  StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                                  HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bg" Property="Background" Value="#22000000"/>
                                <Setter TargetName="glyph" Property="Stroke" Value="#202020"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="bg" Property="Background" Value="#E81123"/>
                                <Setter TargetName="glyph" Property="Stroke" Value="White"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            </Style>
        </ResourceDictionary>
    </Application.Resources>
</Application>
